generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  username              String    @unique
  password              String
  displayName           String?
  avatar                String?
  bio                   String?
  ageGroup              String?
  city                  String?
  streak                Int       @default(0)
  lastLogDate           DateTime?
  profileClass          String    @default("undetermined")
  profileClassUpdatedAt DateTime?
  createdAt             DateTime  @default(now())

  personalLogs       PersonalLog[]
  anonymousLogs      AnonymousLog[]
  stepCounts         StepCount[]
  sleepSessions      SleepSession[]
  audioRecordings    AudioRecording[]
  photoAttachments   PhotoAttachment[]
  waterIntakes       WaterIntake[]
  chatInsights       ChatInsight[]
  feedbacks          Feedback[]
  meditationSessions MeditationSession[]
  notifications      Notification[]
}

model MeditationSound {
  id          String   @id
  name        String
  description String
  url         String
  fileSizeMB  Float
  durationSec Int
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions MeditationSession[]
}

model MeditationSession {
  id          String   @id @default(cuid())
  userId      String
  soundId     String
  targetMin   Int
  actualMin   Int
  completed   Boolean  @default(false)
  startedAt   DateTime
  completedAt DateTime
  createdAt   DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sound MeditationSound @relation(fields: [soundId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, startedAt])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model ChatInsight {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime
  alertLevel       String   @default("low")
  alertScore       Float    @default(0)
  messageCount     Int      @default(0)
  keywords         String[]
  notableSentences String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model PersonalLog {
  id         String   @id @default(cuid())
  userId     String
  mood       String
  moodScore  Int
  factors    String[]
  note       String?
  nlpScore   Float?
  nlpEmotion String?
  alertLevel String?
  createdAt  DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id])
  audioRecordings  AudioRecording[]
  photoAttachments PhotoAttachment[]
}

model AudioRecording {
  id        String   @id @default(cuid())
  logId     String
  userId    String
  url       String
  publicId  String
  label     String
  createdAt DateTime @default(now())

  log  PersonalLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])
}

model PhotoAttachment {
  id        String   @id @default(cuid())
  logId     String
  userId    String
  url       String
  publicId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  log  PersonalLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])
}

model AnonymousLog {
  id         String   @id @default(cuid())
  userId     String
  mood       String
  moodScore  Int
  factors    String[]
  nlpScore   Float?
  nlpEmotion String?
  ageGroup   String?
  city       String?
  lang       String   @default("vi")
  hour       Int
  dayOfWeek  Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model StepCount {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  steps     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model WaterIntake {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  glasses   Int      @default(0)
  goal      Int      @default(8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model SleepSession {
  id        String   @id @default(cuid())
  userId    String
  bedtime   DateTime
  wakeTime  DateTime
  duration  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
